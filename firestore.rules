rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────
    // Helpers
    // ─────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    // Manager: reads everything, writes nothing. Use isStaff() in READ
    // positions only — never in write positions.
    function isStaff() {
      return isSignedIn() && (userRole() == 'admin' || userRole() == 'manager');
    }

    function isProjectMember(pid) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/projects/$(pid)/members/$(request.auth.uid));
    }

    function memberPermissions(pid) {
      return get(/databases/$(database)/documents/projects/$(pid)/members/$(request.auth.uid)).data.permissions;
    }

    function hasProjectPerm(pid, perm) {
      return isAdmin() || (isProjectMember(pid) && perm in memberPermissions(pid));
    }

    // ─────────────────────────────────────────────────────
    // Users — admins manage; workers read their own doc.
    // ─────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isMe(uid) || isStaff();
      allow create, delete: if isAdmin();
      // Workers may edit their own profile details but can never touch
      // role, active status, or project assignments.
      allow update: if isAdmin() ||
        (isMe(uid) &&
         request.resource.data.role == resource.data.role &&
         request.resource.data.active == resource.data.active &&
         request.resource.data.projectIds == resource.data.projectIds);
    }

    // ─────────────────────────────────────────────────────
    // Projects
    // ─────────────────────────────────────────────────────

    match /projects/{pid} {
      allow read: if isStaff() || isProjectMember(pid);
      allow create, update, delete: if isAdmin();

      // Members — admins manage
      match /members/{uid} {
        allow read: if isMe(uid) || isStaff() || isProjectMember(pid);
        allow write: if isAdmin();
      }

      // Plans — view requires project access; foremen and admin upload.
      match /plans/{planId} {
        allow read: if isProjectMember(pid) || isStaff();
        allow create, update: if isAdmin() ||
                                 hasProjectPerm(pid, 'supervisor.forms.approve');
        allow delete: if isAdmin();

        // Pin-tasks on the drawing: foremen create/assign; the assigned
        // worker can mark their own pin done; foremen/admin accept.
        match /pins/{pinId} {
          allow read: if isProjectMember(pid) || isStaff();
          allow create: if isAdmin() ||
                           hasProjectPerm(pid, 'supervisor.forms.approve');
          allow update: if isAdmin() ||
                           hasProjectPerm(pid, 'supervisor.forms.approve') ||
                           (resource.data.assigneeUid == request.auth.uid &&
                            request.resource.data.status != 'accepted');
          allow delete: if isAdmin();
        }
      }

      // Media — workers w/ upload perm can create; only the uploader or admin can delete
      match /media/{mediaId} {
        allow read: if isProjectMember(pid) || isStaff();
        allow create: if hasProjectPerm(pid, 'worker.media.upload') &&
                         request.resource.data.uploadedBy == request.auth.uid;
        allow update: if isAdmin();
        allow delete: if isAdmin() ||
                         (resource.data.uploadedBy == request.auth.uid);
      }

      // Submissions — workers with submit perm can create their own;
      // only admins and supervisors with approve perm can read others'.
      match /submissions/{subId} {
        allow read: if isStaff() ||
                       (isProjectMember(pid) && (
                         resource.data.submittedBy == request.auth.uid ||
                         hasProjectPerm(pid, 'supervisor.forms.approve')
                       ));
        allow create: if hasProjectPerm(pid, 'worker.forms.submit') &&
                         request.resource.data.submittedBy == request.auth.uid;
        // PDF path is appended server-side by Cloud Function.
        // Owner may update their own submission same-day only (End of Day
        // answers at clock-out) — schemaId and submittedBy must not change.
        allow update: if isAdmin() ||
                         (resource.data.submittedBy == request.auth.uid &&
                          request.resource.data.submittedBy == resource.data.submittedBy &&
                          request.resource.data.schemaId == resource.data.schemaId &&
                          request.time.toMillis() - resource.data.submittedAt.toMillis() < 24 * 60 * 60 * 1000);
        allow delete: if isAdmin();
      }

      // Attendance — workers see their own; supervisors see project-wide
      match /attendance/{attId} {
        allow read: if isStaff() ||
                       resource.data.uid == request.auth.uid ||
                       hasProjectPerm(pid, 'supervisor.attendance.clockout-others');

        // Create: only for yourself
        allow create: if isProjectMember(pid) &&
                         request.resource.data.uid == request.auth.uid;

        // Update: admin and approvers can do anything; foremen can clock out
        // others; a worker can update their own shift but can never set
        // status to 'approved' (no self-approval).
        allow update: if isAdmin() ||
                         hasProjectPerm(pid, 'supervisor.attendance.approve') ||
                         hasProjectPerm(pid, 'supervisor.attendance.clockout-others') ||
                         (resource.data.uid == request.auth.uid &&
                          request.resource.data.status != 'approved');

        allow delete: if isAdmin();
      }

      // Work log — members post their own entries; foremen/admin can amend.
      match /workLog/{entryId} {
        allow read: if isStaff() || isProjectMember(pid);
        allow create: if isProjectMember(pid) &&
                         request.resource.data.uid == request.auth.uid;
        allow update: if isAdmin() ||
                         hasProjectPerm(pid, 'supervisor.forms.approve') ||
                         resource.data.uid == request.auth.uid;
        allow delete: if isAdmin();
      }

      // Deficiencies (punch list) — any project member can report; admins
      // and supervisors can update status/resolve.
      match /deficiencies/{defId} {
        allow read: if isStaff() || isProjectMember(pid);
        allow create: if isProjectMember(pid) &&
                         request.resource.data.reportedBy == request.auth.uid;
        allow update: if isAdmin() ||
                         hasProjectPerm(pid, 'supervisor.forms.approve') ||
                         resource.data.reportedBy == request.auth.uid;
        allow delete: if isAdmin();
      }

      // Expenses (job costing from receipts) — project members can record;
      // admins manage. Supervisor can approve in v0.3.
      match /expenses/{expId} {
        allow read: if isStaff() || isProjectMember(pid);
        allow create: if isProjectMember(pid) &&
                         request.resource.data.recordedBy == request.auth.uid;
        allow update: if isAdmin() ||
                         resource.data.recordedBy == request.auth.uid;
        allow delete: if isAdmin();
      }

      // Daily logs — one per date. Supervisors and admins write; project
      // members can read.
      match /dailyLogs/{date} {
        allow read: if isStaff() || isProjectMember(pid);
        allow create, update: if isAdmin() ||
                                  hasProjectPerm(pid, 'supervisor.forms.approve') ||
                                  isProjectMember(pid); // any member for v0.2; v0.3 restricts
        allow delete: if isAdmin();
      }
    }

    // ─────────────────────────────────────────────────────
    // User certifications — workers manage their own; admins read all.
    // ─────────────────────────────────────────────────────

    match /users/{uid}/certifications/{certId} {
      allow read: if isMe(uid) || isStaff();
      allow create, update, delete: if isMe(uid) || isAdmin();
    }

    // Worker notifications — written by Cloud Functions; worker reads own,
    // marks own as read.
    match /users/{uid}/notifications/{nid} {
      allow read, update: if isMe(uid) || isStaff();
      allow create, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────
    // Form schemas — read by anyone signed in, write by admin.
    // ─────────────────────────────────────────────────────

    match /forms/{formId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────
    // Templates — read by anyone signed in, write by admin.
    // ─────────────────────────────────────────────────────

    match /templates/{tid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────
    // Dashboard config — read by signed-in, write by admin.
    // ─────────────────────────────────────────────────────

    match /dashboards/{role}/modules/{mid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────
    // Notifications — office inbox. Written by Cloud Functions
    // (Admin SDK bypasses rules); admins read + mark read.
    // ─────────────────────────────────────────────────────

    match /notifications/{nid} {
      allow read, update: if isStaff(); // manager reads inbox + marks read
      allow create, delete: if isAdmin();
    }
  }
}
